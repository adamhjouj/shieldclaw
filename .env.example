# Auth0 tenant
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your_shieldclaw_app_client_id
AUTH0_CLIENT_SECRET=your_shieldclaw_app_client_secret
AUTH0_AUDIENCE=https://shieldclaw-gateway
AUTH0_ALGORITHMS=RS256

# Auth0 Management API credentials (for creating agent M2M apps)
# These need: read:clients, create:clients, delete:clients, create:client_grants
AUTH0_MGMT_CLIENT_ID=your_mgmt_api_client_id
AUTH0_MGMT_CLIENT_SECRET=your_mgmt_api_client_secret

# OpenClaw upstream
OPENCLAW_UPSTREAM=http://127.0.0.1:18789
SHIELDCLAW_PORT=8443

# AI evaluation (optional — enables natural language policy parsing + ShieldBot)
ANTHROPIC_API_KEY=sk-ant-...

# Discord onboarding bot (optional)
DISCORD_BOT_TOKEN=your_discord_bot_token

# For CLI usage
SHIELDCLAW_URL=http://localhost:8443
# SHIELDCLAW_ADMIN_TOKEN=your_admin_jwt_here

# Dev bypass — skips Auth0 JWT verification entirely. NEVER set in production.
# DEV_BYPASS=true

# Auth0 FGA (Fine-Grained Authorization)
FGA_API_URL=https://api.us1.fga.dev
FGA_STORE_ID=your_fga_store_id
FGA_API_TOKEN_ISSUER=fga.us.auth0.com
FGA_API_AUDIENCE=https://api.us1.fga.dev/
FGA_CLIENT_ID=your_fga_client_id
FGA_CLIENT_SECRET=your_fga_client_secret
# FGA_MODEL_ID=  # set after running: python scripts/setup_fga.py

# -----------------------------------------------------------------------
# COLLABORATION NOTE
# -----------------------------------------------------------------------
# Never commit .env — it's in .gitignore.
# Each developer gets their own .env with their own values.
#
# To onboard a teammate:
#   1. Copy this file to .env
#   2. Fill in your Auth0 tenant credentials
#   3. Get the MGMT secret from the team password manager (not Slack/email)
#
# To rotate a secret:
#   1. Rotate it in Auth0 / the issuing service
#   2. Update your local .env
#   3. Redeploy — vault.invalidate() will pick up the new value on restart
#
# Future: swap vault.py backend to AWS Secrets Manager / GCP Secret Manager
# so developers never see raw secret values at all.
# -----------------------------------------------------------------------
